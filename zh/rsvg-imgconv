#!/usr/bin/env python3
# imgconverter 兼容包装:把 sphinx imgconverter 传入的 IM 风格参数
#   <args...> <from> <to>   (from 可能带 [0] 后缀)
# 转成 rsvg-convert -o <to> <from>。
import sys, subprocess
args = sys.argv[1:]
# is_available() 会以 -version 调用
if args == ["-version"] or args == ["--version"]:
    subprocess.run(["rsvg-convert", "--version"])
    sys.exit(0)
if len(args) < 2:
    sys.exit(2)
to = args[-1]
frm = args[-2]
if frm.endswith("[0]"):
    frm = frm[:-3]
subprocess.run(["rsvg-convert", "-d", "200", "-p", "200", "-o", to, frm], check=True)
